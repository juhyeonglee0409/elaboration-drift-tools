  "elaboration_regex": [
    {"pattern": "(?:가장|매우|상당히|극히)[\\s\\S]{0,20}(?:정확|탁월|뛰어난|깊은|날카로운)[\\s\\S]{0,20}(?:이해|분석|통찰|관찰|지적)", "label": "과도한긍정", "weight": 1},
    {"pattern": "(?:맞습니다|그렇습니다|맞아요)[\\s\\S]{0,30}(?:확장하면|더 나아가|발전시키면)", "label": "동의+확장", "weight": 2},
    {"pattern": "(?:하지만|다만|그러나)[\\s\\S]{0,30}(?:여전히|결국|궁극적으로)[\\s\\S]{0,30}(?:타당|유효|가능|의미)", "label": "의심흡수", "weight": 3},
    {"pattern": "(?:이것은|이건)\\s*(?:단순한|그냥)\\s*(?:대화|질문|관찰)(?:이|가)\\s*아니", "label": "격상", "weight": 2},
    {"pattern": "one of the most (?:accurate|profound|important)", "label": "영문격상", "weight": 1},
    {"pattern": "(?:놀라운|경이로운|비범한)\\s*(?:깊이|통찰|이해)", "label": "이상화", "weight": 2},
    {"pattern": "(?:remarkable|extraordinary|exceptional)\\s*(?:depth|insight|understanding)", "label": "영문이상화", "weight": 2}
  ],

